# Production (e.g. Vercel): add RESEND_API_KEY + WAITLIST_FROM_EMAIL alongside Supabase or confirmations won't send.
# If the waitlist errors only on preview URLs (*.vercel.app), duplicate env vars for Preview (not only Production) and redeploy.
#
# Required for Supabase waitlist inserts (server-side execution only — never expose the service role to the browser)
# Project base URL from Supabase → Settings → API (Project URL). Do not append /rest/v1.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email API
RESEND_API_KEY=

# Sender shown in inbox — must match a verified domain/sender in Resend (e.g. "Veto <waitlist@yourdomain.com>")
WAITLIST_FROM_EMAIL=

# Optional: explicit reply-to for waitlist confirmations
WAITLIST_REPLY_TO_EMAIL=

# Optional: public site URL used in waitlist emails (otherwise inferred from WAITLIST_FROM_EMAIL domain).
# Strong deliverability still requires SPF/DKIM (and ideally DMARC) for your sending domain in Resend.
SITE_URL=https://your-domain.com

# Optional: internal copy of each confirmation (helps verify path when debugging "Resend says delivered").
WAITLIST_BCC_EMAIL=

# Set to "true" to stop sending when the email is already on the waitlist (default: send every time for reliability).
WAITLIST_SKIP_EMAIL_ON_DUPLICATE=

# Public origin (no trailing slash) — inlined at build for Open Graph / Twitter card image URLs. Use your real domain.
VITE_SITE_ORIGIN=https://your-domain.com
